; Koch curve
(define (koch p1 p2 depth img)
  (if (zero? depth)
      (draw-line p1 p2 "black" img)
      (let* ([a (point-at-fraction p1 p2 1/3)]
             [b (point-at-fraction p1 p2 2/3)]
             [peak (rotate-point a b (- (/ pi 3)))])
        (koch p1 a (- depth 1)
              (koch a peak (- depth 1)
                    (koch peak b (- depth 1)
                          (koch b p2 (- depth 1) img)))))))
      


;(koch (cons 0 11) (cons 320 250) 1 (rectangle 300 300 "solid" "orange"))




; test


; Koch snowflake

(define (koch-snowflake center size depth)
  (let* ([p1 (cons (car center) (- (cdr center) size))]
         [p2 (rotate-point p1 center (/ (* pi 2) 3))]
         [p3 (rotate-point p1 center (/ (* pi 4) 3))]
         [back (rectangle (* 3 size) (* 3 size) "solid" "orange")])
    (koch p1 p2 depth
          (koch p2 p3 depth
                (koch p3 p1 depth back)))))


; test
(koch-snowflake (cons 100 100) 100 5)

