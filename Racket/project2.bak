; rotate-point

;(define (test-func)
 ; (let ([x (+ 4 5)]) x))
;(test-func)


(define (translate-point point origin)
  (cons (- (car origin) (car point)) (- (cdr origin) (cdr point))))
;(define (translate-back point origin)
 ; (cons (+ (car origin) (car point)) (+ (cdr origin) (cdr point))))

(define (rotate-point point origin rot)
  (let* ([t-point (translate-point point origin)]
         [rotated-x (- (* (car t-point) (cos rot)) (* (cdr t-point) (sin rot)))]
         [rotated-y (+ (* (car t-point) (sin rot)) (* (cdr t-point) (cos rot)))])
    (translate-point (cons rotated-x rotated-y) origin)))
    






;    Translate the point so the center is at the origin
;   Apply rotation: x' = x*cos(angle) - y*sin(angle), y' = x*sin(angle) + y*cos(angle)
;  Translate back

